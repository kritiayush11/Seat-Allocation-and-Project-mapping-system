# Copy this file to backend/.env and fill in your values

# Database — use SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite:///./ethara_seats.db
# DATABASE_URL=postgresql://user:password@localhost:5432/ethara_seats

# OpenAI (optional — AI assistant falls back to rule-based if not set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# App
DEBUG=true
APP_TITLE=Ethara Seat Allocation & Project Mapping System
APP_VERSION=1.0.0

# CORS origins (comma-separated in production)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
