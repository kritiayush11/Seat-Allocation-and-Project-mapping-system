# Copy this file to backend/.env and fill in your values

# Database — use SQLite for local dev, PostgreSQL for production
DATABASE_URL=
# DATABASE_URL=postgresql://user:password@localhost:5432/ethara_seats

# JWT — set a long random string; if omitted locally a random key is generated per session
# In Docker/production this MUST be set so tokens survive restarts
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# BCrypt rounds — default 12 (production). Lower to 10 for faster local dev.
# Each +1 doubles hash time. rounds=12 → ~220ms, rounds=10 → ~55ms.
# NEVER set below 10 in production.
BCRYPT_ROUNDS=12

# OpenAI (optional — AI assistant falls back to rule-based if not set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# App
DEBUG=true
APP_TITLE=Ethara Seat Allocation & Project Mapping System
APP_VERSION=1.0.0

# CORS origins (comma-separated in production)
ALLOWED_ORIGINS=
